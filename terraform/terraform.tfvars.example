# Copy this file to terraform.tfvars and set secure values locally.
# Never commit terraform.tfvars to source control.

kubeconfig_path = "~/.kube/config"
namespace       = "data-stack"
domain          = "dakar-datasphere-node.local"
minio_root_user = "admin"

minio_root_password      = "replace-with-strong-password"
unity_catalog_admin_token = "replace-with-unity-catalog-token"
grafana_admin_password   = "replace-with-grafana-admin-password"
airflow_fernet_key       = "replace-with-airflow-fernet-key"
airflow_webserver_secret_key = "replace-with-airflow-webserver-secret-key"
airflow_admin_password   = "replace-with-airflow-admin-password"

postgres_superuser_password = "replace-with-postgres-superuser-password"
postgres_app_password       = "replace-with-postgres-app-password"

postgres_image_repository = "postgres-health-ext"
postgres_image_tag        = "16"
postgres_database         = "health_node"
postgres_app_user         = "health_app"
postgres_persistence_size = "50Gi"
postgres_backup_schedule  = "0 2 * * *"
postgres_backup_retention_days = 7
postgres_backup_history_limit  = 5
postgres_backup_pvc_size       = "20Gi"

storage_class                 = "local-path"
pgbouncer_pool_mode           = "transaction"
pgbouncer_max_client_conn     = 500
pgbouncer_default_pool_size   = 40
pgbouncer_reserve_pool_size   = 10

deploy_optional_local_charts = false
